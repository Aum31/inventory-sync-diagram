# ==============================================================================
# ENVIRONMENT CONFIGURATIONS FOR AUTOMATED OUTREACH
# Rename this file to '.env' and fill in your details to activate live notifications.
# ==============================================================================

# 1. DISCORD CONFIGURATIONS
# Go to your Discord server -> Edit Channel -> Integrations -> Webhooks -> Create Webhook.
# Copy the Webhook URL and paste it here.
DISCORD_WEBHOOK_URL=YOUR_DISCORD_WEBHOOK_URL_HERE

# 2. EMAIL SMTP CONFIGURATIONS (For sending cold outreach)
# For Gmail: Use 'smtp.gmail.com' and port 587.
# Important: Do not use your normal Gmail password. You must generate an 
# "App Password" under your Google Account Security Settings.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here

# 3. TEST EMAIL TARGET (Where test emails are sent so you don't spam real targets)
TEST_RECIPIENT_EMAIL=your_test_inbox@gmail.com

# 4. UPWORK RSS FEED URL (For automated job monitoring)
UPWORK_RSS_URL=YOUR_UPWORK_RSS_URL_HERE

# 5. B2B LEAD MINING API KEYS (Free/Low-cost tiers)
# Google Places API Key (For local business/distributor discovery)
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY_HERE

# Apollo.io API Key (For targeted B2B contact and tech stack queries)
APOLLO_API_KEY=YOUR_APOLLO_API_KEY_HERE

# BuiltWith API Key (For verifying WooCommerce/Shopify technology stacks)
BUILTWITH_API_KEY=YOUR_BUILTWITH_API_KEY_HERE

# Hunter.io API Key (For finding contact emails of company domains)
HUNTER_API_KEY=YOUR_HUNTER_API_KEY_HERE

